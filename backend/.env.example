# FastAPI Backend Configuration
FASTAPI_URL=http://localhost:8000

# Database Configuration
DATABASE_URL=postgresql://hommes:hommes123@localhost:5432/hommesestates

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Document Storage
DOCUMENT_STORAGE_PATH=./storage/documents

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@hommesestates.com

# Branding
BRAND_NAME=Hommes Estates
BRAND_LOGO_URL=/logo.png
BRAND_PRIMARY_COLOR=#1a365d

# Optional: Odoo Integration (for migration)
ODOO_API_URL=http://localhost:8069
ODOO_DB=odoo_18
ODOO_USERNAME=admin
ODOO_PASSWORD=admin
